# WordPress GraphQL Endpoint (ต้องเข้าถึงได้จากเซิร์ฟเวอร์ Coolify)
WPGRAPHQL_ENDPOINT=https://cms.webuy.in.th/webuy/graphql

# Site URL (PRODUCTION - เปลี่ยนเป็น domain จริง!)
SITE_URL=https://YOUR-DOMAIN.com

# Site Key
SITE_KEY=webuy

# รายการหน้าแรก/หมวด/พื้นที่: ค่าเริ่มต้นไม่กรองฟิลด์ site (เหมือน webuy-hub-v2)
# ต้องการแยกเนื้อหาตาม SITE_KEY: SITE_STRICT_HUB_LISTINGS=1
# SITE_STRICT_HUB_LISTINGS=1

# Coolify/Docker build: ถ้า WP บล็อก IP หรือ 403 ระหว่าง build ให้เปิด fallback (ค่า default ในโค้ดจะเปิดเองตอน `npm run build` แล้ว)
# บังคับปิดเพื่อให้ build ล้มเมื่อ WP ไม่ตอบ: WP_FALLBACK_ON_ERROR=0
# WP_FALLBACK_ON_ERROR=1

# Google Analytics (Optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
